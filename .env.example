# Brain Agent v2 — Environment Variables
# Copy this file to .env and fill in your values.
# Usage: source .env (or use python-dotenv)

# Required: Google Gemini API key for embeddings
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=

# Optional: Ollama configuration (default LLM provider)
OLLAMA_MODEL=qwen3.5:4b-nothink
OLLAMA_BASE_URL=http://localhost:11434

# Optional: OpenRouter configuration (cloud LLM alternative)
# If set, overrides Ollama as the LLM provider
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct

# Optional: Agent configuration overrides
# BRAIN_AGENT_MODEL=qwen3.5:4b
# BRAIN_AGENT_DB=~/.brain_agent/memory.db
# BRAIN_AGENT_DEBUG=false
